{
  "name": "edunova",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm:dev\" -w client \"npm:dev\" -w server",
    "build": "npm -w client run build && npm -w server run build",
    "start": "npm -w server start",
    "lint": "npm -w client run lint && npm -w server run lint",
    "seed": "npm -w server run seed"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}

